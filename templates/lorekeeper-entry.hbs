<form class="lorekeeper-editor-form">
  <div class="form-group">
    <label>{{localize "LOREKEEPER.Type"}}</label>
    <select name="type">
      {{#each entryTypes}}
      <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>{{localize "LOREKEEPER.TitleGM"}}</label>
    <input type="text" name="titleGM" value="{{entry.titleGM}}">
  </div>
  <div class="form-group">
    <label>{{localize "LOREKEEPER.TitlePlayer"}}</label>
    <input type="text" name="titlePlayer" value="{{entry.titlePlayer}}">
  </div>
  <div class="form-group lorekeeper-image-field">
    <label>{{localize "LOREKEEPER.Image"}}</label>
    <input type="text" name="image" value="{{entry.image}}" placeholder="worlds/my-world/assets/image.webp">
    <button type="button" data-action="pick-image"><i class="fas fa-file-import"></i></button>
  </div>
  <div class="form-group stacked">
    <label>{{localize "LOREKEEPER.DescriptionGM"}}</label>
    <textarea name="descriptionGM">{{entry.descriptionGM}}</textarea>
  </div>
  <div class="form-group stacked">
    <label>{{localize "LOREKEEPER.DescriptionPlayer"}}</label>
    <textarea name="descriptionPlayer">{{entry.descriptionPlayer}}</textarea>
  </div>
  <div class="form-group">
    <label>{{localize "LOREKEEPER.Tags"}}</label>
    <input type="text" name="tags" value="{{entry.tags}}">
  </div>
  <fieldset>
    <legend>{{localize "LOREKEEPER.Permissions"}}</legend>
    <div class="form-group">
      <label>{{localize "LOREKEEPER.DefaultPermission"}}</label>
      <select name="defaultPermission">
        <option value="none" {{#if defaultPermissionNone}}selected{{/if}}>{{localize "LOREKEEPER.PermissionNone"}}</option>
        <option value="read" {{#if defaultPermissionRead}}selected{{/if}}>{{localize "LOREKEEPER.PermissionRead"}}</option>
      </select>
    </div>
    {{#each users}}
    <div class="form-group">
      <label>{{name}}</label>
      <select name="permission-{{id}}">
        <option value="none" {{#if permissionNone}}selected{{/if}}>{{localize "LOREKEEPER.PermissionNone"}}</option>
        <option value="read" {{#if permissionRead}}selected{{/if}}>{{localize "LOREKEEPER.PermissionRead"}}</option>
      </select>
    </div>
    {{/each}}
  </fieldset>
  <footer class="lorekeeper-dialog-actions">
    <button type="submit"><i class="fas fa-save"></i> {{localize "LOREKEEPER.Save"}}</button>
  </footer>
</form>
